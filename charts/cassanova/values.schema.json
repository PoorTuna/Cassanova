{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of replicas"
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      },
      "required": ["repository"]
    },
    "config": {
      "type": "object",
      "properties": {
        "appConfig": {
          "type": "object",
          "properties": {
            "host": { "type": "string", "default": "0.0.0.0" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 8080 },
            "routers": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "required": ["port"]
        },
        "tls": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "certFile": { "type": "string" },
            "keyFile": { "type": "string" },
            "caBundle": { "type": "string" },
            "minTlsVersion": { "type": "string", "enum": ["TLSv1_2", "TLSv1_3"] },
            "enforceHttps": { "type": "boolean" },
            "hstsEnabled": { "type": "boolean" },
            "hstsMaxAge": { "type": "integer", "minimum": 0 }
          }
        },
        "auth": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "secretKey": { "type": "string", "description": "JWT signing key. Use existingSecret for production." },
            "algorithm": { "type": "string", "default": "HS256" },
            "sessionExpireMinutes": { "type": "integer", "minimum": 1, "default": 120 },
            "users": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" },
                  "roles": { "type": "array", "items": { "type": "string" } }
                },
                "required": ["username", "password", "roles"]
              }
            },
            "roles": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "permissions": { "type": "array", "items": { "type": "string" } }
                },
                "required": ["name", "permissions"]
              }
            },
            "ldap": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean", "default": false },
                "serverUri": { "type": "string" },
                "bindDn": { "type": "string" },
                "bindPassword": { "type": "string" },
                "baseDn": { "type": "string" },
                "userSearchFilter": { "type": "string" },
                "roleMapping": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } },
                "defaultRoles": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "clusters": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "contactPoints": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1,
                "description": "Cassandra node addresses"
              },
              "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 9042 },
              "credentials": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["username", "password"]
              },
              "localDc": { "type": "string", "description": "Preferred local datacenter" }
            },
            "required": ["contactPoints"]
          }
        },
        "k8s": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "namespace": { "type": "string" },
            "suffix": { "type": "string", "default": "-service" },
            "periodicDiscoveryEnabled": { "type": "boolean", "default": false },
            "discoveryIntervalSeconds": { "type": "integer", "minimum": 10, "default": 60 },
            "nodeRecovery": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean", "default": false }
              }
            }
          }
        }
      }
    },
    "existingSecret": {
      "type": "string",
      "description": "Name of an existing Secret containing cassanova.json"
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean", "default": true },
        "annotations": { "type": "object" },
        "name": { "type": "string" },
        "rbac": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean", "default": false },
            "clusterWide": { "type": "boolean", "default": false }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"], "default": "ClusterIP" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 8080 }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": { "type": "string" },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": { "type": "string" },
                    "pathType": { "type": "string", "enum": ["Prefix", "Exact", "ImplementationSpecific"] }
                  }
                }
              }
            }
          }
        },
        "tls": { "type": "array" }
      }
    },
    "route": {
      "type": "object",
      "description": "OpenShift Route configuration",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "host": { "type": "string" },
        "path": { "type": "string" },
        "annotations": { "type": "object" },
        "tls": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "termination": { "type": "string", "enum": ["edge", "passthrough", "reencrypt"], "default": "edge" },
            "insecureEdgeTerminationPolicy": { "type": "string", "enum": ["Allow", "Redirect", "None"], "default": "Redirect" },
            "certificate": { "type": "string" },
            "key": { "type": "string" },
            "caCertificate": { "type": "string" }
          }
        }
      }
    },
    "resources": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "extraEnv": { "type": "array" },
    "extraVolumeMounts": { "type": "array" },
    "extraVolumes": { "type": "array" }
  }
}
